# India MCP — Environment Variables

# Delhivery API (for logistics server)
# Get from: https://track.delhivery.com/settings/api
DELHIVERY_TOKEN=your_delhivery_token_here

# DigiLocker API (for identity/document server)
# Get from: https://digitallocker.gov.in/developer/
DIGILOCKER_CLIENT_ID=your_client_id_here
DIGILOCKER_CLIENT_SECRET=your_client_secret_here

# Optional: Pre-generated access token (for testing without OAuth flow)
# DIGILOCKER_ACCESS_TOKEN=

# Railways API (optional - for live data)
# ERAIL_API_KEY=your_erail_key_here