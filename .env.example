# Delhivery API Token (get from https://track.delhivery.com/settings/api)
DELHIVERY_TOKEN=your_token_here

# DigiLocker API Credentials (register at https://digitallocker.gov.in/developer/)
DIGILOCKER_CLIENT_ID=your_client_id
DIGILOCKER_CLIENT_SECRET=your_client_secret
# Optional: Pre-generated access token (for testing without OAuth flow)
DIGILOCKER_ACCESS_TOKEN=