{
  "name": "@samarth-23-eng/india-mcp",
  "version": "1.0.16",
  "mcpName": "io.github.Samarth-23-eng/india-mcp",
  "description": "Production-grade MCP servers for Indian APIs - Stocks (NSE/BSE), Banking (IFSC/UPI), GST, Railways, and RTO.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "india",
    "nse",
    "bse",
    "stocks",
    "gst",
    "railways",
    "ai",
    "claude",
    "cursor"
  ],
  "author": {
    "name": "Samarth-23-eng",
    "url": "https://github.com/Samarth-23-eng"
  },
  "bugs": {
    "url": "https://github.com/Samarth-23-eng/India-MCP/issues"
  },
  "license": "MIT",
  "homepage": "https://github.com/Samarth-23-eng/India-MCP#readme",
  "type": "module",
  "bin": {
    "india-mcp": "./dist/cli.js",
    "india-mcp-gst": "./dist/servers/gst-server-entry.js",
    "india-mcp-railways": "./dist/servers/railways-server-entry.js",
    "india-mcp-rto": "./dist/servers/rto-server-entry.js",
    "india-mcp-banking": "./dist/servers/banking-server-entry.js",
    "india-mcp-stocks": "./dist/servers/stocks-server-entry.js",
    "india-mcp-delhivery": "./dist/servers/delhivery-server-entry.js",
    "india-mcp-digilocker": "./dist/servers/digilocker-server-entry.js",
    "india-mcp-ecourts": "./dist/servers/ecourts-server-entry.js",
    "india-mcp-fssai": "./dist/servers/fssai-server-entry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Samarth-23-eng/India-MCP.git"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:client": "ts-node --esm src/test-client.ts",
    "gst": "ts-node --esm src/servers/gst-server-entry.ts",
    "delhivery": "ts-node --esm src/servers/delhivery-server-entry.ts",
    "digilocker": "ts-node --esm src/servers/digilocker-server-entry.ts",
    "railways": "ts-node --esm src/servers/railways-server-entry.ts",
    "rto": "ts-node --esm src/servers/rto-server-entry.ts",
    "banking": "ts-node --esm src/servers/banking-server-entry.ts",
    "stocks": "ts-node --esm src/servers/stocks-server-entry.ts",
    "ecourts": "ts-node --esm src/servers/ecourts-server-entry.ts",
    "fssai": "ts-node --esm src/servers/fssai-server-entry.ts",
    "build": "tsc",
    "generate-docs": "ts-node --esm scripts/generate-docs.ts",
    "validate:publish": "tsc && dir dist\\servers\\*-entry.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
