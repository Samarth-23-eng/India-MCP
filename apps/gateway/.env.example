# India-MCP Gateway Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# PostgreSQL connection string
# Example: postgresql://postgres:password@localhost:5432/india_mcp
DATABASE_URL=postgresql://postgres:password@localhost:5432/india_mcp

# Secret key for JWT token signing (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-random-secret-here-min-32-chars

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Server port (default: 3001)
PORT=3001

# Environment mode
NODE_ENV=development

# CORS allowed origins (comma-separated)
# Include your Vercel deployment URL and localhost for development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004,https://your-app.vercel.app

# ===========================================
# PRODUCTION NOTES
# ===========================================

# For Railway deployment:
# 1. Set DATABASE_URL to your Railway PostgreSQL instance
# 2. Set JWT_SECRET to a secure random string
# 3. Add your Vercel domain to ALLOWED_ORIGINS
# 4. Set NODE_ENV=production

# For local development:
# 1. Use SQLite: DATABASE_URL=file:./dev.db
# 2. Or PostgreSQL if you have it installed
# 3. ALLOWED_ORIGINS can include localhost only
